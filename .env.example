# ─────────────────────────────────────────────────────────────
# CodexDominion Command Console — environment configuration
#
# The application runs ZERO-CONFIG in DEMO mode on a typed seed
# layer. Everything for DATABASE mode below is OPTIONAL and only
# needed when wiring the console to a live Supabase backend.
# ─────────────────────────────────────────────────────────────

# Data source mode: "demo" (default) | "database"
# DEMO     → typed seed data, no backend required (safe for public preview)
# DATABASE → Prisma / Supabase Postgres
NEXT_PUBLIC_APP_MODE=demo

# Supabase (Auth + Postgres). Required only in DATABASE mode / for auth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma — pooled + direct connection strings from Supabase.
DATABASE_URL=
DIRECT_URL=

# Auth gate. Leave false for credential-free demos.
NEXT_PUBLIC_REQUIRE_AUTH=false

# Optional demo access code (used when REQUIRE_AUTH is false).
NEXT_PUBLIC_DEMO_ACCESS_CODE=
