# ─────────────────────────────────────────────────────────────
# CodexDominion Command Console — environment configuration
#
# The application runs ZERO-CONFIG on a typed seed-data layer.
# Everything below is OPTIONAL and only required when wiring the
# console to a live Supabase backend for production pilots.
# ─────────────────────────────────────────────────────────────

# Supabase (Auth + Postgres). Leave unset to run in demo/seed mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma — pooled + direct connection strings from Supabase.
DATABASE_URL=
DIRECT_URL=

# Feature flags
# Set to "true" to require authentication on all console routes.
NEXT_PUBLIC_REQUIRE_AUTH=false

# Demo access gate (used when REQUIRE_AUTH is false). Optional.
NEXT_PUBLIC_DEMO_ACCESS_CODE=
